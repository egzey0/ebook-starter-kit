# === WYMAGANE ===

# Stripe (stripe.com/dashboard)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Opcjonalnie: ID cennika ze Stripe Dashboard (jeśli pusty, cena brana z kodu)
STRIPE_PRICE_ID=

# Resend (resend.com/api-keys)
RESEND_API_KEY=re_...
# ID listy mailingowej z Resend Audiences (opcjonalne)
RESEND_AUDIENCE_ID=

# Bezpieczeństwo tokena pobierania (wymyśl losowy ciąg, np. openssl rand -hex 32)
TOKEN_SECRET=zmien-na-losowy-ciag-minimum-32-znaki

# URL Twojej strony (bez / na końcu)
SITE_URL=https://twojadomena.pl

# === OPCJONALNE (faktury) ===

# Fakturownia (app.fakturownia.pl/account/settings)
FAKTUROWNIA_TOKEN=
# Subdomena Twojego konta, np. "mojafirma" z mojafirma.fakturownia.pl
FAKTUROWNIA_DOMAIN=

# === OPCJONALNE (analityka) ===

# Google Analytics 4 (analytics.google.com)
# Wklej Measurement ID, np. G-XXXXXXXXXX
GA4_ID=

# Meta Pixel (business.facebook.com/events_manager)
META_PIXEL_ID=
